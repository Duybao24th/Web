@model List<Order>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    var statusFlow = ViewBag.StatusFlow as string[];

    string StatusBadge(string status) => status switch
    {
        "Chờ xử lý" => "bg-warning text-dark",
        "Đang giao hàng" => "bg-info text-dark",
        "Đã giao hàng" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <select name="status" class="form-select form-select-sm" style="width:200px" onchange="this.form.submit()">
            <option value="">-- Tất cả trạng thái --</option>
            @foreach (var s in statusFlow)
            {
                <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
            }
        </select>
    </form>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Khách Hàng</th>
                    <th>Ngày Đặt</th>
                    <th class="text-end">Tổng Tiền</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-end">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="fw-semibold">#DS@(o.Id.ToString("D6"))</td>
                        <td>@o.Customer?.FullName</td>
                        <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">@o.TotalMoney.ToString("N0") đ</td>
                        <td class="text-center"><span class="badge @StatusBadge(o.Status)">@o.Status</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">Chi Tiết</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Không có đơn hàng nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if ((int)ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@ViewBag.Status">@i</a>
                </li>
            }
        </ul>
    </nav>
}
