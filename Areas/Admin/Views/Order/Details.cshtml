@model Order
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
    var statusFlow = ViewBag.StatusFlow as string[];

    string StatusBadge(string status) => status switch
    {
        "Chờ xử lý" => "bg-warning text-dark",
        "Đang giao hàng" => "bg-info text-dark",
        "Đã giao hàng" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Đơn Hàng #DS@(Model.Id.ToString("D6"))</h5>
    <span class="badge @StatusBadge(Model.Status) fs-6">@Model.Status</span>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-bold">Sản Phẩm Đã Đặt</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Sản Phẩm</th><th class="text-center">SL</th><th class="text-end">Đơn Giá</th><th class="text-end">Thành Tiền</th></tr></thead>
                    <tbody>
                        @foreach (var od in Model.OrderDetails)
                        {
                            <tr>
                                <td>@od.Product?.ProductName</td>
                                <td class="text-center">@od.Quantity</td>
                                <td class="text-end">@od.UnitPrice.ToString("N0") đ</td>
                                <td class="text-end fw-semibold">@((od.Quantity * od.UnitPrice).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="border-top">
                            <td colspan="3" class="fw-bold">Tổng Cộng</td>
                            <td class="text-end fw-bold price-tag">@Model.TotalMoney.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">Thông Tin Khách Hàng</h6>
                <p class="mb-1"><strong>Khách hàng:</strong> @Model.Customer?.FullName (@Model.Customer?.Username)</p>
                <p class="mb-1"><strong>Người nhận:</strong> @Model.ReceiverName</p>
                <p class="mb-1"><strong>SĐT:</strong> @Model.ReceiverPhone</p>
                <p class="mb-1"><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                <p class="mb-1"><strong>Thanh toán:</strong> @Model.PaymentMethod</p>
                <p class="mb-0"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <p class="mb-0 mt-2"><strong>Ghi chú:</strong> @Model.Note</p>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3">Cập Nhật Trạng Thái</h6>
                <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                    <select name="status" class="form-select">
                        @foreach (var s in statusFlow)
                        {
                            <option value="@s" selected="@(s == Model.Status)">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary text-nowrap"><i class="bi bi-check-lg"></i> Cập Nhật</button>
                </form>
            </div>
        </div>
    </div>
</div>
