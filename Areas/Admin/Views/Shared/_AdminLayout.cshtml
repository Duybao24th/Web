@{
    var admin = ViewBag.CurrentAdmin as SessionCustomer;
    string CurrentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string IsActive(string controller) => CurrentController == controller ? "active" : "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DrinkStore Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <aside class="admin-sidebar text-light p-3" style="width:250px; flex-shrink:0;">
            <a class="d-flex align-items-center gap-2 text-decoration-none text-white mb-4 px-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-cup-straw fs-3 text-primary"></i>
                <span class="fs-5 fw-bold">DrinkStore <small class="d-block text-secondary" style="font-size:.7rem">TRANG QUẢN TRỊ</small></span>
            </a>
            <ul class="nav nav-pills flex-column gap-1">
                <li class="nav-item">
                    <a class="nav-link @IsActive("Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i> Tổng Quan
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @IsActive("Category")" asp-area="Admin" asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tags me-2"></i> Danh Mục
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @IsActive("Product")" asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam me-2"></i> Sản Phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @IsActive("Order")" asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i> Đơn Hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @IsActive("Customer")" asp-area="Admin" asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people me-2"></i> Khách Hàng
                    </a>
                </li>
                <li class="nav-item mt-3 border-top border-secondary pt-3">
                    <a class="nav-link" asp-controller="Home" asp-action="Index" asp-area="">
                        <i class="bi bi-shop me-2"></i> Về Trang Bán Hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout" asp-area="">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng Xuất
                    </a>
                </li>
            </ul>
        </aside>

        <main class="flex-grow-1" style="min-width:0;">
            <nav class="navbar navbar-light bg-white shadow-sm px-4 py-3">
                <span class="fw-bold fs-5">@ViewData["Title"]</span>
                <span class="d-flex align-items-center gap-2">
                    <i class="bi bi-person-circle fs-4 text-primary"></i>
                    <span class="fw-semibold">@admin?.FullName</span>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Quản trị viên</span>
                </span>
            </nav>

            <div class="p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
