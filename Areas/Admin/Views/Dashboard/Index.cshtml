@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Tổng Quan";
    string StatusBadge(string status) => status switch
    {
        "Chờ xử lý" => "bg-warning text-dark",
        "Đang giao hàng" => "bg-info text-dark",
        "Đã giao hàng" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
        <div class="card stat-card bg-1">
            <div class="card-body">
                <i class="bi bi-currency-dollar fs-2"></i>
                <h4 class="fw-bold mt-2 mb-0">@Model.TotalRevenue.ToString("N0") đ</h4>
                <div class="small opacity-75">Tổng Doanh Thu</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card bg-2">
            <div class="card-body">
                <i class="bi bi-receipt fs-2"></i>
                <h4 class="fw-bold mt-2 mb-0">@Model.TotalOrders</h4>
                <div class="small opacity-75">Tổng Đơn Hàng (@Model.PendingOrders chờ xử lý)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card bg-3">
            <div class="card-body">
                <i class="bi bi-box-seam fs-2"></i>
                <h4 class="fw-bold mt-2 mb-0">@Model.TotalProducts</h4>
                <div class="small opacity-75">Sản Phẩm (@Model.TotalCategories danh mục)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card stat-card bg-4">
            <div class="card-body">
                <i class="bi bi-people fs-2"></i>
                <h4 class="fw-bold mt-2 mb-0">@Model.TotalCustomers</h4>
                <div class="small opacity-75">Khách Hàng</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold">Đơn Hàng Gần Đây</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr><th>Mã Đơn</th><th>Khách Hàng</th><th>Ngày Đặt</th><th>Tổng Tiền</th><th>Trạng Thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders)
                        {
                            <tr>
                                <td><a asp-controller="Order" asp-action="Details" asp-route-id="@o.Id">#DS@(o.Id.ToString("D6"))</a></td>
                                <td>@o.Customer?.FullName</td>
                                <td>@o.OrderDate.ToString("dd/MM/yyyy")</td>
                                <td>@o.TotalMoney.ToString("N0") đ</td>
                                <td><span class="badge @StatusBadge(o.Status)">@o.Status</span></td>
                            </tr>
                        }
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">Chưa có đơn hàng nào</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold">Sản Phẩm Bán Chạy</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr><th>Sản Phẩm</th><th class="text-center">Đã Bán</th><th class="text-end">Doanh Thu</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.TopProducts)
                        {
                            <tr>
                                <td class="small">@t.ProductName</td>
                                <td class="text-center">@t.TotalSold</td>
                                <td class="text-end">@t.TotalRevenue.ToString("N0") đ</td>
                            </tr>
                        }
                        @if (!Model.TopProducts.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.LowStockProducts.Any())
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white fw-bold text-danger"><i class="bi bi-exclamation-triangle"></i> Sắp Hết Hàng</div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.LowStockProducts)
                    {
                        <li class="list-group-item d-flex justify-content-between small">
                            <span>@p.ProductName</span>
                            <span class="fw-bold text-danger">Còn @p.Quantity</span>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
