@model Category
@{
    ViewData["Title"] = "Xóa Danh Mục";
}

<div class="card border-0 shadow-sm" style="max-width:600px">
    <div class="card-body p-4">
        <h5 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Xác Nhận Xóa</h5>
        <p>Bạn có chắc chắn muốn xóa danh mục <strong>@Model.Name</strong>?</p>
        @if (Model.Products.Any())
        {
            <div class="alert alert-warning small">Danh mục này đang chứa <strong>@Model.Products.Count</strong> sản phẩm. Vui lòng chuyển các sản phẩm sang danh mục khác trước khi xóa.</div>
        }
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger" @(Model.Products.Any() ? "disabled" : "")><i class="bi bi-trash"></i> Xác Nhận Xóa</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </form>
    </div>
</div>
