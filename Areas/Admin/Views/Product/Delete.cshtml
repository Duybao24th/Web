@model Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="card border-0 shadow-sm" style="max-width:600px">
    <div class="card-body p-4">
        <h5 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Xác Nhận Xóa</h5>
        <div class="d-flex align-items-center gap-3 my-3">
            <img src="@Model.Image" style="width:60px;height:60px;object-fit:contain;background:#f8fafc;border-radius:.5rem" onerror="this.style.display='none'">
            <div>
                <div class="fw-semibold">@Model.ProductName</div>
                <div class="text-muted small">@Model.Category?.Name · @Model.Price.ToString("N0") đ</div>
            </div>
        </div>
        <p class="text-muted small">Nếu sản phẩm đã phát sinh đơn hàng, hệ thống sẽ tự động chuyển sang trạng thái "Ngừng bán" thay vì xóa cứng để đảm bảo toàn vẹn dữ liệu lịch sử đơn hàng.</p>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xác Nhận</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </form>
    </div>
</div>
