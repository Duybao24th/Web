@{
    var cartItems = Context.Session.GetObject<List<CartItem>>(DrinkStore.Controllers.CartController.CART_KEY);
    var cartCount = cartItems?.Sum(c => c.Quantity) ?? 0;
    var currentUser = Context.Session.GetObjectOrNull<SessionCustomer>(DrinkStore.Controllers.AccountController.SESSION_USER_KEY);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DrinkStore</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%232563eb'><path d='M5 2l1.5 4h11L19 2H5zm.9 6L8 20a2 2 0 002 2h4a2 2 0 002-2l2.1-12H5.9z'/></svg>" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="sticky-top">
        <div class="topbar d-none d-md-block">
            <div class="container d-flex justify-content-between small py-1">
                <span><i class="bi bi-telephone-fill me-1"></i> Hotline: 1900 6789 &nbsp;|&nbsp; <i class="bi bi-geo-alt-fill me-1"></i> Giao hàng toàn quốc</span>
                <span>Đăng ký thành viên nhận ưu đãi đến 10%</span>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cup-straw text-primary"></i> Drink<span class="text-primary">Store</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Sản Phẩm</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Giới Thiệu</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Liên Hệ</a></li>
                    </ul>
                    <form class="d-flex me-3" style="max-width:320px" asp-controller="Product" asp-action="Index" method="get">
                        <input class="form-control form-control-sm" type="search" name="search" placeholder="Tìm sản phẩm...">
                        <button class="btn btn-primary btn-sm ms-1" type="submit"><i class="bi bi-search"></i></button>
                    </form>
                    <ul class="navbar-nav align-items-lg-center gap-2">
                        <li class="nav-item">
                            <a class="btn btn-outline-primary btn-sm position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i> Giỏ Hàng
                                @if (cartCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@cartCount</span>
                                }
                            </a>
                        </li>
                        @if (currentUser == null)
                        {
                            <li class="nav-item"><a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Đăng Nhập</a></li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="btn btn-light btn-sm dropdown-toggle border" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @currentUser.FullName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (currentUser.IsAdmin)
                                    {
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Trang Quản Trị</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Hồ Sơ Của Tôi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="MyOrders"><i class="bi bi-bag-check me-2"></i>Đơn Hàng Của Tôi</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng Xuất</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-light pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-cup-straw text-primary"></i> DrinkStore</h4>
                    <p class="text-secondary">Cửa hàng nước giải khát trực tuyến uy tín, đa dạng sản phẩm từ nước ngọt, trà, cà phê đến nước tăng lực với giá tốt nhất thị trường.</p>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-bold mb-3">Danh Mục</h6>
                    <ul class="list-unstyled text-secondary">
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-secondary text-decoration-none">Nước ngọt</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-secondary text-decoration-none">Trà</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-secondary text-decoration-none">Cà phê</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-secondary text-decoration-none">Nước tăng lực</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-6">
                    <h6 class="fw-bold mb-3">Hỗ Trợ</h6>
                    <ul class="list-unstyled text-secondary">
                        <li class="mb-2"><a asp-controller="Home" asp-action="About" class="text-secondary text-decoration-none">Về chúng tôi</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact" class="text-secondary text-decoration-none">Liên hệ</a></li>
                        <li class="mb-2"><a asp-controller="Order" asp-action="MyOrders" class="text-secondary text-decoration-none">Tra cứu đơn hàng</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Liên Hệ</h6>
                    <ul class="list-unstyled text-secondary">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>123 Đường Lê Lợi, Q1, TP.HCM</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i>1900 6789</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>support@drinkstore.com</li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary">
            <p class="text-center text-secondary mb-0 small">&copy; @DateTime.Now.Year DrinkStore. Đồ án môn học ASP.NET Core MVC.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
