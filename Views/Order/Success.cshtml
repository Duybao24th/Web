@model Order
@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <i class="bi bi-check-circle-fill text-success display-1"></i>
        <h2 class="fw-bold mt-3">Đặt Hàng Thành Công!</h2>
        <p class="text-muted">Cảm ơn bạn đã mua sắm tại DrinkStore. Mã đơn hàng của bạn là <strong>#DS@(Model.Id.ToString("D6"))</strong></p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="text-muted small">Người nhận</div>
                            <div class="fw-semibold">@Model.ReceiverName</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">Số điện thoại</div>
                            <div class="fw-semibold">@Model.ReceiverPhone</div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted small">Địa chỉ giao hàng</div>
                        <div class="fw-semibold">@Model.ShippingAddress</div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted small">Phương thức thanh toán</div>
                        <div class="fw-semibold">@Model.PaymentMethod</div>
                    </div>
                    <hr>
                    <table class="table table-borderless mb-0">
                        <tbody>
                        @foreach (var od in Model.OrderDetails)
                        {
                            <tr>
                                <td>@od.Product?.ProductName <span class="text-muted">x@od.Quantity</span></td>
                                <td class="text-end">@((od.Quantity * od.UnitPrice).ToString("N0")) đ</td>
                            </tr>
                        }
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td class="fw-bold">Tổng Cộng</td>
                                <td class="text-end fw-bold price-tag fs-5">@Model.TotalMoney.ToString("N0") đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary me-2">Về Trang Chủ</a>
                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-primary">Xem Đơn Hàng Của Tôi</a>
            </div>
        </div>
    </div>
</div>
