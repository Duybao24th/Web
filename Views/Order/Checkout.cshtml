@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
}

<div class="container py-4">
    <h2 class="section-title mb-4">Thanh Toán Đơn Hàng</h2>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form asp-controller="Order" asp-action="Checkout" method="post">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-truck"></i> Thông Tin Giao Hàng</h5>
                        <div class="mb-3">
                            <label asp-for="ReceiverName" class="form-label"></label>
                            <input asp-for="ReceiverName" class="form-control" />
                            <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ReceiverPhone" class="form-label"></label>
                            <input asp-for="ReceiverPhone" class="form-control" />
                            <span asp-validation-for="ReceiverPhone" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label"></label>
                            <textarea asp-for="ShippingAddress" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label"></label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ví dụ: Giao hàng giờ hành chính..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-credit-card"></i> Phương Thức Thanh Toán</h5>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="COD" id="payCod" checked>
                            <label class="form-check-label" for="payCod">Thanh toán khi nhận hàng (COD)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Chuyển khoản" id="payTransfer">
                            <label class="form-check-label" for="payTransfer">Chuyển khoản ngân hàng</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Đơn Hàng (@Model.CartItems.Count sản phẩm)</h5>
                        <div style="max-height:280px; overflow-y:auto;">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@item.Image" class="cart-item-thumb" style="width:50px;height:50px;" alt=""
                                             onerror="this.onerror=null;this.src='https://placehold.co/60x60/f8fafc/94a3b8?text=DS';">
                                        <div>
                                            <div class="small fw-semibold">@item.ProductName</div>
                                            <div class="text-muted small">x@item.Quantity</div>
                                        </div>
                                    </div>
                                    <span class="small fw-semibold">@item.SubTotal.ToString("N0") đ</span>
                                </div>
                            }
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính</span>
                            <span>@Model.TotalMoney.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fw-bold">Tổng Cộng</span>
                            <span class="fw-bold price-tag fs-5">@Model.TotalMoney.ToString("N0") đ</span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-check-circle"></i> Đặt Hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
