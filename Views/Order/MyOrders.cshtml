@model List<Order>
@{
    ViewData["Title"] = "Đơn Hàng Của Tôi";

    string StatusBadge(string status) => status switch
    {
        "Chờ xử lý" => "bg-warning text-dark",
        "Đang giao hàng" => "bg-info text-dark",
        "Đã giao hàng" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container py-4">
    <h2 class="section-title mb-4">Đơn Hàng Của Tôi</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <p class="mt-3 text-muted fs-5">Bạn chưa có đơn hàng nào.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-2">Mua Sắm Ngay</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Ngày Đặt</th>
                            <th>Số Sản Phẩm</th>
                            <th>Tổng Tiền</th>
                            <th>Trạng Thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-semibold">#DS@(order.Id.ToString("D6"))</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.OrderDetails.Sum(od => od.Quantity)</td>
                                <td class="price-tag">@order.TotalMoney.ToString("N0") đ</td>
                                <td><span class="badge @StatusBadge(order.Status)">@order.Status</span></td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Chi Tiết</a>
                                    @if (order.Status == "Chờ xử lý")
                                    {
                                        <form asp-action="Cancel" asp-route-id="@order.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">Hủy</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
