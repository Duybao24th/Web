@model ProductListViewModel
@{
    ViewData["Title"] = "Sản Phẩm";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Sản phẩm</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-3 mb-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-list-ul"></i> Danh Mục</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <a asp-action="Index" class="text-decoration-none @(Model.SelectedCategoryId == null ? "fw-bold text-primary" : "text-dark")">
                                <i class="bi bi-grid me-1"></i> Tất cả sản phẩm
                            </a>
                        </li>
                        @foreach (var cat in Model.Categories)
                        {
                            <li class="mb-2">
                                <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-search="@Model.SearchTerm"
                                   class="text-decoration-none @(Model.SelectedCategoryId == cat.Id ? "fw-bold text-primary" : "text-dark")">
                                    <i class="bi bi-caret-right-fill me-1"></i> @cat.Name
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-search"></i> Tìm Kiếm</h6>
                    <form asp-action="Index" method="get">
                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                        <div class="input-group">
                            <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Tên sản phẩm, thương hiệu...">
                            <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                <div class="text-muted">Tìm thấy <strong>@Model.TotalItems</strong> sản phẩm</div>
                <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    <input type="hidden" name="search" value="@Model.SearchTerm" />
                    <label class="small text-muted mb-0">Sắp xếp:</label>
                    <select name="sort" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.SortOrder))">Nổi bật</option>
                        <option value="newest" selected="@(Model.SortOrder == "newest")">Mới nhất</option>
                        <option value="price_asc" selected="@(Model.SortOrder == "price_asc")">Giá tăng dần</option>
                        <option value="price_desc" selected="@(Model.SortOrder == "price_desc")">Giá giảm dần</option>
                        <option value="name_asc" selected="@(Model.SortOrder == "name_asc")">Tên A-Z</option>
                    </select>
                </form>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-emoji-frown display-3 text-muted"></i>
                    <p class="mt-3 text-muted">Không tìm thấy sản phẩm phù hợp.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var p in Model.Products)
                    {
                        <partial name="_ProductCard" model="p" />
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-categoryId="@Model.SelectedCategoryId"
                                       asp-route-search="@Model.SearchTerm"
                                       asp-route-sort="@Model.SortOrder"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
