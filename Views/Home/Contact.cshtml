@{
    ViewData["Title"] = "Liên Hệ";
}

<div class="container py-5">
    <h2 class="section-title mb-4">Liên Hệ Với Chúng Tôi</h2>
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Thông Tin Liên Hệ</h6>
                    <p class="text-muted mb-2"><i class="bi bi-geo-alt text-primary me-2"></i>123 Đường Lê Lợi, Quận 1, TP. Hồ Chí Minh</p>
                    <p class="text-muted mb-2"><i class="bi bi-telephone text-primary me-2"></i>1900 6789</p>
                    <p class="text-muted mb-2"><i class="bi bi-envelope text-primary me-2"></i>support@drinkstore.com</p>
                    <p class="text-muted mb-0"><i class="bi bi-clock text-primary me-2"></i>7:00 - 22:00 (Tất cả các ngày trong tuần)</p>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Gửi Tin Nhắn Cho Chúng Tôi</h6>
                    <form asp-controller="Home" asp-action="Contact" method="post">
                        <div class="mb-3">
                            <label class="form-label">Họ Tên</label>
                            <input type="text" name="fullName" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nội Dung</label>
                            <textarea name="message" class="form-control" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Gửi Tin Nhắn</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
