@{
    ViewData["Title"] = "Giới Thiệu";
}

<div class="container py-5">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h2 class="section-title mb-4">Về DrinkStore</h2>
            <p class="text-muted">DrinkStore là hệ thống cửa hàng nước giải khát trực tuyến, cung cấp đa dạng các sản phẩm từ nước ngọt có ga, trà đóng chai, cà phê lon, nước ép trái cây, nước khoáng, sữa cho đến nước tăng lực.</p>
            <p class="text-muted">Chúng tôi cam kết mang đến sản phẩm chính hãng, giá cả hợp lý và dịch vụ giao hàng nhanh chóng tận nơi trên toàn quốc.</p>
            <ul class="list-unstyled text-muted">
                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-2"></i>Hơn 20+ sản phẩm đa dạng thương hiệu</li>
                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-2"></i>Cam kết hàng chính hãng 100%</li>
                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-2"></i>Giao hàng nhanh trong 2 giờ nội thành</li>
                <li class="mb-2"><i class="bi bi-check2-circle text-primary me-2"></i>Hỗ trợ khách hàng 24/7</li>
            </ul>
        </div>
        <div class="col-lg-6 text-center">
            <i class="bi bi-shop-window" style="font-size:14rem;color:#dbeafe;"></i>
        </div>
    </div>
</div>
